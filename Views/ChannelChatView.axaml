<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaApplication1.ViewModels"
             xmlns:dto="using:AvaloniaApplication1.DTO"
             x:Class="AvaloniaApplication1.Views.ChannelChatView"
             x:DataType="vm:ChannelChatViewModel">

    <UserControl.Styles>
        <Style Selector="Border.letter">
            <Setter Property="Background" Value="#1FCBA75A"/>
            <Setter Property="BorderBrush" Value="#33CBA75A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <!-- header -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="#" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource BrassBrush}"/>
            <TextBlock Text="{Binding ChannelName}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource ParchmentBrush}"/>
        </StackPanel>

        <!-- status -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
                   FontSize="12" FontStyle="Italic" Margin="0,8,0,0"
                   Foreground="{StaticResource BrassBrush}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <!-- composer -->
        <Border DockPanel.Dock="Bottom" Classes="card" Margin="0,12,0,0" Padding="10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Watermark="Send a message to the chamber..."
                         Text="{Binding Draft}" AcceptsReturn="False">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SendCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Grid.Column="1" Classes="primary small" Content="Send" Margin="10,0,0,0"
                        VerticalAlignment="Stretch" Command="{Binding SendCommand}"/>
            </Grid>
        </Border>

        <!-- thread -->
		<ScrollViewer Name="ThreadScroll">
            <StackPanel Spacing="8">
                <Button Classes="ghost" Content="Load older messages"
                        HorizontalAlignment="Center" Margin="0,0,0,4"
                        Command="{Binding LoadOlderCommand}"/>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:MessageItem">
							<Border Classes="letter" Margin="0,0,0,2">
								<DockPanel>
									<!-- avatar: initial letter underneath, image on top when loaded -->
									<Panel DockPanel.Dock="Left" Width="34" Height="34" Margin="0,0,10,0" VerticalAlignment="Top">
										<Border CornerRadius="17"
												Background="#33CBA75A" BorderBrush="#66CBA75A" BorderThickness="1">
											<TextBlock Text="{Binding Initial}" FontWeight="SemiBold"
													   Foreground="{StaticResource ParchmentBrush}"
													   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<Border CornerRadius="17" ClipToBounds="True"
												IsVisible="{Binding Avatar, Converter={x:Static ObjectConverters.IsNotNull}}">
											<Image Source="{Binding Avatar}" Width="34" Height="34" Stretch="UniformToFill"/>
										</Border>
									</Panel>

									<StackPanel Spacing="3">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="{Binding Username}" FontSize="12" FontWeight="SemiBold"
													   Foreground="{StaticResource BrassBrush}"/>
											<TextBlock Text="{Binding SentAt}" FontSize="10" Opacity="0.6"
													   Foreground="{StaticResource BrassBrush}" VerticalAlignment="Center"/>
											<TextBlock Text="(edited)" FontSize="10" Opacity="0.6" FontStyle="Italic"
													   Foreground="{StaticResource BrassBrush}" VerticalAlignment="Center"
													   IsVisible="{Binding Edited}"/>
										</StackPanel>
										<TextBlock Text="{Binding Message}" TextWrapping="Wrap"
												   Foreground="{StaticResource ParchmentBrush}"/>
									</StackPanel>
								</DockPanel>
							</Border>
						</DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
